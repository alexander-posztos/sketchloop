# vhs tape: record replay.sh (a scripted Claude Code-style session) to build/term.mp4.
# Run from demo/: vhs demo.tape
Output build/term.mp4

Set Shell bash
Set FontSize 19
Set Width 1000
Set Height 760
Set Padding 24
Set Theme "Catppuccin Mocha"
Set CursorBlink false

Hide
Type "bash replay.sh"
Enter
Show
Sleep 9
